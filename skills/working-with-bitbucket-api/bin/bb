#!/usr/bin/env bash
# bb — Bitbucket Cloud CLI (gh-style wrapper around REST API v2)
set -euo pipefail

BB_VERSION="1.0.0"
# BB_API_URL lets the test suite redirect API calls to a local mock server.
# It is restricted to loopback so it can never be used to exfiltrate the
# auth token (sent as HTTP Basic on every call) to a remote host — there is
# no legitimate reason to point the Bitbucket Cloud CLI at a non-local host.
# Unset in production, where BB_API is the real Bitbucket API.
if [[ -n "${BB_API_URL:-}" ]]; then
  if [[ "$BB_API_URL" =~ ^https?://(localhost|127\.0\.0\.1|\[::1\])(:[0-9]+)?(/|$) ]]; then
    BB_API="$BB_API_URL"
  else
    echo >&2 "error: BB_API_URL must point to a loopback host (localhost, 127.0.0.1, ::1)"
    exit 1
  fi
else
  BB_API="https://api.bitbucket.org/2.0"
fi

# --- Auth -------------------------------------------------------------------

bb_token() {
  if [[ -n "${BB_TOKEN:-}" ]]; then
    echo "$BB_TOKEN"
    return
  fi
  local token
  token="$(security find-generic-password -s "com.quatico.bitbucket-cli" -a "token" -w 2>/dev/null)" || {
    echo >&2 "error: no Bitbucket API token found"
    echo >&2 "  Run: bb auth login"
    echo >&2 "  Or export BB_TOKEN=<token>"
    exit 1
  }
  echo "$token"
}

bb_email() {
  if [[ -n "${BB_EMAIL:-}" ]]; then
    echo "$BB_EMAIL"
    return
  fi
  security find-generic-password -s "com.quatico.bitbucket-cli" -a "email" -w 2>/dev/null || {
    echo >&2 "error: no email found — run: bb auth login"
    exit 1
  }
}

# --- Repo detection ----------------------------------------------------------

bb_parse_remote() {
  local url
  url="$(git remote get-url origin 2>/dev/null)" || {
    echo >&2 "error: not a git repository or no 'origin' remote"
    exit 1
  }
  # SSH:  git@bitbucket.org:workspace/repo.git
  # HTTPS: https://bitbucket.org/workspace/repo.git
  if [[ "$url" != *bitbucket.org* ]]; then
    echo >&2 "error: origin remote is not a bitbucket.org URL: $url"
    echo >&2 "  Use -R workspace/repo to specify the repository"
    exit 1
  fi
  local path
  path="$(echo "$url" | sed -E 's#^(git@bitbucket\.org:|https://[^@]*@bitbucket\.org/|https://bitbucket\.org/)##; s/\.git$//')"
  echo "$path"
}

bb_workspace() {
  if [[ -n "${_BB_WORKSPACE:-}" ]]; then
    echo "$_BB_WORKSPACE"
  else
    bb_parse_remote | cut -d/ -f1
  fi
}

bb_repo() {
  if [[ -n "${_BB_REPO:-}" ]]; then
    echo "$_BB_REPO"
  else
    bb_parse_remote | cut -d/ -f2
  fi
}

# --- Unicode helpers ---------------------------------------------------------

bb_nfc() {
  # Normalize Unicode string to NFC (composed form).
  # macOS terminals emit NFD (decomposed: a + combining ¨); Bitbucket API returns NFC (ä).
  # Without normalization, byte-level == in jq fails on names like "Bänziger".
  perl -CSA -MUnicode::Normalize -e 'print NFC(join(" ", @ARGV))' -- "$@"
}

# --- User resolution ---------------------------------------------------------

bb_resolve_user() {
  # Resolve a reviewer identifier to a JSON object for the reviewers array.
  # Returns {account_id} or {uuid}. Accepts: UUID ({...}), account_id (24-char hex), or display name.
  local input="$1"

  # UUID — use directly
  if [[ "$input" == \{*\} ]]; then
    jq -n --arg uuid "$input" '{"uuid": $uuid}'
    return
  fi

  # Account ID — 24-char hex
  if [[ "$input" =~ ^[0-9a-f]{24}$ ]]; then
    jq -n --arg id "$input" '{"account_id": $id}'
    return
  fi

  # Display name — search PR participants in the current repo
  input="$(bb_nfc "$input")"
  local ws repo
  ws="$(bb_workspace)"
  repo="$(bb_repo)"
  local prs account_id
  prs="$(bb_paginate "/repositories/${ws}/${repo}/pullrequests?state=MERGED" 50)" || prs="[]"
  account_id="$(echo "$prs" | jq -r --arg name "$input" '
    [.[] | (.author, .reviewers[]?) |
     select(.display_name == $name or .nickname == $name) |
     .account_id] | first // empty')"

  if [[ -z "$account_id" ]]; then
    # Also search open PRs
    prs="$(bb_paginate "/repositories/${ws}/${repo}/pullrequests?state=OPEN" 50)" || prs="[]"
    account_id="$(echo "$prs" | jq -r --arg name "$input" '
      [.[] | (.author, .reviewers[]?) |
       select(.display_name == $name or .nickname == $name) |
       .account_id] | first // empty')"
  fi

  if [[ -z "$account_id" ]]; then
    echo >&2 "error: cannot resolve reviewer '$input'"
    echo >&2 "  Use account_id (24-char hex) or UUID ({...}) directly"
    echo >&2 "  Or check: bb -R $ws/$repo pr list --state merged --json | jq '.[].reviewers[].display_name'"
    return 1
  fi

  jq -n --arg id "$account_id" '{"account_id": $id}'
}

# --- HTTP core ---------------------------------------------------------------

bb_api_call() {
  local method="$1" path="$2"; shift 2
  local token email
  token="$(bb_token)" || exit 1
  email="$(bb_email)" || exit 1
  local response http_code
  response="$(curl -sSL -w "\n%{http_code}" -X "$method" \
    -u "${email}:${token}" \
    -H "Content-Type: application/json" \
    -H "Accept: application/json" \
    "$@" \
    "${BB_API}${path}")"
  http_code="$(echo "$response" | tail -1)"
  local body
  body="$(echo "$response" | sed '$d')"

  if [[ "$http_code" -ge 400 ]]; then
    local msg
    msg="$(echo "$body" | jq -r '.error.message // .error // "unknown error"' 2>/dev/null)" || msg="$body"
    echo >&2 "error: HTTP $http_code — $msg"
    return 1
  fi
  echo "$body"
}

bb_paginate() {
  local path="$1"; shift
  local limit="${1:-50}"
  local all="[]"
  local url="${BB_API}${path}"
  local token email
  token="$(bb_token)" || exit 1
  email="$(bb_email)" || exit 1
  local page=0

  while [[ -n "$url" && "$page" -lt 10 ]]; do
    local response http_code
    response="$(curl -sSL -w "\n%{http_code}" -X GET \
      -u "${email}:${token}" \
      -H "Accept: application/json" \
      "$url")"
    http_code="$(echo "$response" | tail -1)"
    local body
    body="$(echo "$response" | sed '$d')"

    if [[ "$http_code" -ge 400 ]]; then
      local msg
      msg="$(echo "$body" | jq -r '.error.message // .error // "unknown error"' 2>/dev/null)" || msg="$body"
      echo >&2 "error: HTTP $http_code — $msg"
      return 1
    fi

    local values
    values="$(echo "$body" | jq '.values // []')"
    all="$(jq -n --argjson a "$all" --argjson b "$values" '$a + $b')"

    local count
    count="$(echo "$all" | jq 'length')"
    if [[ "$count" -ge "$limit" ]]; then
      all="$(echo "$all" | jq --argjson l "$limit" '.[:$l]')"
      break
    fi

    url="$(echo "$body" | jq -r '.next // empty')"
    page=$((page + 1))
  done
  echo "$all"
}

bb_api_raw() {
  local path="$1"; shift
  local token email
  token="$(bb_token)" || exit 1
  email="$(bb_email)" || exit 1
  local response http_code
  response="$(curl -sSL -w "\n%{http_code}" -X GET \
    -u "${email}:${token}" \
    "$@" \
    "${BB_API}${path}")"
  http_code="$(echo "$response" | tail -1)"
  local body
  body="$(echo "$response" | sed '$d')"
  if [[ "$http_code" -ge 400 ]]; then
    local msg
    msg="$(echo "$body" | jq -r '.error.message // .error // "unknown error"' 2>/dev/null)" || msg="$body"
    echo >&2 "error: HTTP $http_code — $msg"
    return 1
  fi
  printf '%s' "$body"
}

bb_current_ref() {
  local ws repo
  ws="$(bb_workspace)"
  repo="$(bb_repo)"
  bb_api_call GET "/repositories/${ws}/${repo}" | jq -r '.mainbranch.name // "main"'
}

# --- Output formatting -------------------------------------------------------

bb_format_pr_list() {
  jq -r '.[] | [
    (.id | tostring),
    (if .draft == true then "DRAFT" else (.state // "OPEN") end),
    (.author.display_name // .author.nickname // "unknown"),
    (.source.branch.name // "?"),
    (.title // "(no title)")
  ] | @tsv' | column -t -s $'\t'
}

bb_format_pr_view() {
  jq -r '
    "Title:    " + (.title // "(no title)"),
    "State:    " + (if .draft == true then "DRAFT" else (.state // "?") end),
    "Author:   " + (.author.display_name // .author.nickname // "?"),
    "Source:   " + (.source.branch.name // "?"),
    "Dest:     " + (.destination.branch.name // "?"),
    "Created:  " + (.created_on // "?"),
    "Updated:  " + (.updated_on // "?"),
    "URL:      " + (.links.html.href // "?"),
    "",
    "Reviewers:",
    ((.reviewers // []) | if length == 0 then "  (none)" else .[] | "  - " + (.display_name // .nickname // "?") end),
    "",
    "---",
    "",
    (.description // "(no description)")'
}

bb_format_comment_list() {
  jq -r '.[] | [
    (.id | tostring),
    (.user.display_name // .user.nickname // "unknown"),
    (.created_on | split("T")[0] // "?"),
    (if .inline then "inline:" + (.inline.path // "?") + ":" + ((.inline.to // .inline.from // 0) | tostring) else "general" end),
    (.content.raw // "(empty)" | gsub("\n"; " ") | .[:80])
  ] | @tsv' | column -t -s $'\t'
}

bb_format_diffstat() {
  jq -r '.[] | [
    .status,
    ("+" + (.lines_added | tostring)),
    ("-" + (.lines_removed | tostring)),
    (.new.path // .old.path // "?")
  ] | @tsv' | column -t -s $'\t'
}

# --- Subcommands: auth -------------------------------------------------------

cmd_auth_status() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --help|-h)
        cat <<'HELP'
Show the currently authenticated Bitbucket user.

USAGE
  bb auth status [--json]

FLAGS
  --json   Output raw JSON from the /user endpoint

EXAMPLES
  bb auth status
  bb auth status --json | jq .account_id
HELP
        exit 0
        ;;
      --json)    JSON_OUTPUT=1; shift ;;
      -*)        echo >&2 "unknown flag: $1"; exit 1 ;;
      *)         echo >&2 "unknown argument: $1"; exit 1 ;;
    esac
  done

  local result
  result="$(bb_api_call GET /user)"
  if [[ "${JSON_OUTPUT:-}" == "1" ]]; then
    echo "$result" | jq .
  else
    echo "$result" | jq -r '"Logged in as: " + (.display_name // "?") + " (" + (.username // "?") + ")"'
    echo "$result" | jq -r '"Account ID:   " + (.account_id // "?")'
    echo "$result" | jq -r '"UUID:         " + (.uuid // "?")'
  fi
}

cmd_auth_login() {
  local email=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --help|-h)
        cat <<'HELP'
Log in with an Atlassian API token. Credentials are stored in macOS Keychain.

USAGE
  bb auth login [--email <email>]

FLAGS
  --email <email>   Atlassian account email (required for non-interactive)

Interactive mode prompts for email and opens the token creation page.
Non-interactive mode reads the token from stdin (requires --email).

Override stored credentials with BB_TOKEN and BB_EMAIL env vars.

EXAMPLES
  bb auth login
  echo "$TOKEN" | bb auth login --email user@example.com
HELP
        exit 0
        ;;
      --email)   email="$2"; shift 2 ;;
      *)         echo >&2 "unknown flag: $1"; exit 1 ;;
    esac
  done

  local token=""
  if [[ -t 0 ]]; then
    # Interactive mode
    [[ -z "$email" ]] && read -rp "Atlassian account email: " email
    echo ""
    local token_url="https://id.atlassian.com/manage-profile/security/api-tokens"
    echo "Create an API token and select these scopes:"
    echo ""
    echo "  - read:user:bitbucket"
    echo "  - read:repository:bitbucket"
    echo "  - read:pullrequest:bitbucket"
    echo "  - write:pullrequest:bitbucket"
    echo "  - write:repository:bitbucket"
    echo ""
    echo "Token page: ${token_url}"
    echo ""
    read -rp "Open in browser? [Y/n] " open_browser
    if [[ "${open_browser:-Y}" =~ ^[Yy]?$ ]]; then
      open "$token_url"
    fi
    echo ""
    read -rsp "Paste your API token: " token
    echo ""
  else
    # Non-interactive: token from stdin, --email required
    [[ -z "$email" ]] && { echo >&2 "error: --email required in non-interactive mode"; exit 1; }
    read -r token
  fi

  [[ -z "$token" ]] && { echo >&2 "error: no token provided"; exit 1; }
  [[ -z "$email" ]] && { echo >&2 "error: no email provided"; exit 1; }

  # Validate token (inline curl — can't use bb_api_call since credentials aren't stored yet)
  local result http_code body
  result="$(curl -sS -w '\n%{http_code}' \
    -u "${email}:${token}" \
    -H "Accept: application/json" \
    "${BB_API}/user")"
  http_code="$(echo "$result" | tail -1)"
  body="$(echo "$result" | sed '$d')"

  if [[ "$http_code" -ge 400 ]]; then
    echo >&2 "error: authentication failed (HTTP ${http_code})"
    [[ "$http_code" == "401" ]] && echo >&2 "  Check that the email and token are correct"
    exit 1
  fi

  local username display_name
  username="$(echo "$body" | jq -r '.username // "?"')"
  display_name="$(echo "$body" | jq -r '.display_name // "?"')"

  # Store in keychain (-U = update if exists, create if not)
  security add-generic-password -U -s "com.quatico.bitbucket-cli" -a "token" -w "$token" || {
    echo >&2 "error: failed to store token in keychain"
    echo >&2 "  Try: security unlock-keychain ~/Library/Keychains/login.keychain-db"
    exit 1
  }
  security add-generic-password -U -s "com.quatico.bitbucket-cli" -a "email" -w "$email" || {
    echo >&2 "error: failed to store email in keychain"
    echo >&2 "  Try: security unlock-keychain ~/Library/Keychains/login.keychain-db"
    exit 1
  }

  echo "Logged in as ${display_name} (${username})"
  echo "Token stored in keychain."
}

# --- Subcommands: pr ---------------------------------------------------------

cmd_pr_list() {
  local state="OPEN" author=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --help|-h)
        cat <<'HELP'
List pull requests in the current repository.

USAGE
  bb pr list [--state <state>] [--author <name>] [--json]

FLAGS
  --state <state>   Filter by state: open, merged, declined, superseded (default: open)
  --author <name>   Filter by author (nickname or display name)
  --json            Output raw JSON array

EXAMPLES
  bb pr list
  bb pr list --state merged
  bb pr list --author alice --json
HELP
        exit 0
        ;;
      --state)
        state="${2^^}"; shift 2
        case "$state" in
          OPEN|MERGED|DECLINED|SUPERSEDED) ;;
          *) echo >&2 "error: invalid --state '$state' (must be open, merged, declined, or superseded)"; exit 1 ;;
        esac
        ;;
      --author)  author="$2"; shift 2 ;;
      --json)    JSON_OUTPUT=1; shift ;;
      *)         echo >&2 "unknown flag: $1"; exit 1 ;;
    esac
  done

  local ws repo path
  ws="$(bb_workspace)"
  repo="$(bb_repo)"
  if [[ -n "$author" ]]; then
    # Try server-side filter by nickname first
    local encoded_author
    encoded_author="$(printf '%s' "$author" | jq -sRr @uri)"
    path="/repositories/${ws}/${repo}/pullrequests?q=state+%3D+%22${state}%22+AND+author.nickname+%3D+%22${encoded_author}%22"
  else
    path="/repositories/${ws}/${repo}/pullrequests?state=${state}"
  fi

  local result
  result="$(bb_paginate "$path")"

  # If author filter returned nothing, fall back to client-side display_name match
  if [[ -n "$author" && "$(echo "$result" | jq 'length')" -eq 0 ]]; then
    path="/repositories/${ws}/${repo}/pullrequests?state=${state}"
    result="$(bb_paginate "$path")"
    local nfc_author
    nfc_author="$(bb_nfc "$author")"
    result="$(echo "$result" | jq --arg name "$nfc_author" '[.[] | select(.author.display_name == $name)]')"
  fi

  if [[ "${JSON_OUTPUT:-}" == "1" ]]; then
    echo "$result" | jq .
  else
    local count
    count="$(echo "$result" | jq 'length')"
    if [[ "$count" -eq 0 ]]; then
      echo "No pull requests match the query"
    else
      echo "ID   STATE   AUTHOR   BRANCH   TITLE"
      echo "$result" | bb_format_pr_list
    fi
  fi
}

cmd_pr_view() {
  local pr_id="" show_comments=0
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --help|-h)
        cat <<'HELP'
View pull request details.

USAGE
  bb pr view <id> [--comments] [--json]

FLAGS
  --comments   Include all comments
  --json       Output raw JSON (with --comments: {pr, comments})

EXAMPLES
  bb pr view 42
  bb pr view 42 --comments
  bb pr view 42 --json | jq .state
HELP
        exit 0
        ;;
      --comments) show_comments=1; shift ;;
      --json)     JSON_OUTPUT=1; shift ;;
      -*)         echo >&2 "unknown flag: $1"; exit 1 ;;
      *)          pr_id="$1"; shift ;;
    esac
  done

  if [[ -z "$pr_id" ]]; then
    echo >&2 "usage: bb pr view <id> [--comments] [--json]"
    exit 1
  fi

  local ws repo
  ws="$(bb_workspace)"
  repo="$(bb_repo)"

  local result
  result="$(bb_api_call GET "/repositories/${ws}/${repo}/pullrequests/${pr_id}")"

  if [[ "${JSON_OUTPUT:-}" == "1" ]]; then
    if [[ "$show_comments" -eq 1 ]]; then
      local comments
      comments="$(bb_paginate "/repositories/${ws}/${repo}/pullrequests/${pr_id}/comments")"
      jq -n --argjson pr "$result" --argjson comments "$comments" '{pr: $pr, comments: $comments}'
    else
      echo "$result" | jq .
    fi
  else
    echo "$result" | bb_format_pr_view
    if [[ "$show_comments" -eq 1 ]]; then
      echo ""
      echo "Comments:"
      local comments
      comments="$(bb_paginate "/repositories/${ws}/${repo}/pullrequests/${pr_id}/comments")"
      local count
      count="$(echo "$comments" | jq 'length')"
      if [[ "$count" -eq 0 ]]; then
        echo "  (no comments)"
      else
        echo "ID   AUTHOR   DATE   LOCATION   TEXT"
        echo "$comments" | bb_format_comment_list
      fi
    fi
  fi
}

cmd_pr_create() {
  local title="" body="" head="" base="" reviewers=() close_branch=0 draft=0
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --help|-h)
        cat <<'HELP'
Create a pull request.

USAGE
  bb pr create --title "..." [--body "..."] [--head <branch>] [--base <branch>]
               [--reviewer <user>] [--close-branch] [--draft] [--json]

FLAGS
  --title <text>      PR title (required)
  --body <text>       PR description (CommonMark markdown — no GFM extensions)
  --head <branch>     Source branch (default: current branch)
  --base <branch>     Target branch (default: repo's default branch via API)
  --reviewer <user>   Add reviewer (repeatable; see REVIEWER RESOLUTION below)
  --close-branch      Close source branch after merge
  --draft             Create PR in draft state
  --json              Output raw JSON

REVIEWER RESOLUTION
  Accepts display name, nickname, UUID ({...}), or account_id (24-char hex).
  Display names are resolved from existing PR participants in the repo.
  For users not on any PR yet, use account_id or UUID directly.

EXAMPLES
  bb pr create --title "Add auth module"
  bb pr create --title "Fix bug" --body "Fixes #42" --reviewer "Alice Smith"
  bb pr create --title "Feature" --head feature/x --base develop --close-branch
  bb pr create --title "WIP" --draft
HELP
        exit 0
        ;;
      --title)        title="$2"; shift 2 ;;
      --body)         body="$2"; shift 2 ;;
      --head)         head="$2"; shift 2 ;;
      --base)         base="$2"; shift 2 ;;
      --reviewer)     reviewers+=("$2"); shift 2 ;;
      --close-branch) close_branch=1; shift ;;
      --draft)        draft=1; shift ;;
      --json)         JSON_OUTPUT=1; shift ;;
      *)              echo >&2 "unknown flag: $1"; exit 1 ;;
    esac
  done

  if [[ -z "$title" ]]; then
    echo >&2 "usage: bb pr create --title \"...\" [--body \"...\"] [--head branch] [--base branch] [--reviewer user] [--close-branch] [--draft]"
    exit 1
  fi

  # Default head to current branch
  [[ -z "$head" ]] && head="$(git branch --show-current 2>/dev/null || echo "")"
  [[ -z "$head" ]] && { echo >&2 "error: cannot detect current branch — use --head"; exit 1; }
  # Default base to the repo's default branch (Bitbucket API → git fallback → "main")
  if [[ -z "$base" ]]; then
    local ws_tmp repo_tmp
    ws_tmp="$(bb_workspace)" 2>/dev/null
    repo_tmp="$(bb_repo)" 2>/dev/null
    base="$(bb_api_call GET "/repositories/${ws_tmp}/${repo_tmp}" 2>/dev/null | jq -r '.mainbranch.name // empty')"
    [[ -z "$base" ]] && base="$(git symbolic-ref refs/remotes/origin/HEAD 2>/dev/null | sed 's|refs/remotes/origin/||')"
    [[ -z "$base" ]] && base="main"
  fi

  local ws repo
  ws="$(bb_workspace)"
  repo="$(bb_repo)"

  local reviewer_json="[]"
  if [[ ${#reviewers[@]} -gt 0 ]]; then
    local resolved=()
    for r in "${reviewers[@]}"; do
      local obj
      obj="$(bb_resolve_user "$r")" || exit 1
      resolved+=("$obj")
    done
    reviewer_json="$(printf '%s\n' "${resolved[@]}" | jq -s '.')"
  fi

  local payload
  payload="$(jq -n \
    --arg title "$title" \
    --arg body "$body" \
    --arg head "$head" \
    --arg base "$base" \
    --argjson close "$close_branch" \
    --argjson draft "$draft" \
    --argjson reviewers "$reviewer_json" \
    '{
      title: $title,
      source: { branch: { name: $head } },
      destination: { branch: { name: $base } },
      close_source_branch: ($close == 1),
      reviewers: $reviewers
    } + (if $body != "" then { description: $body } else {} end)
      + (if $draft == 1 then { draft: true } else {} end)')"

  local result
  result="$(bb_api_call POST "/repositories/${ws}/${repo}/pullrequests" -d "$payload")"

  if [[ "${JSON_OUTPUT:-}" == "1" ]]; then
    echo "$result" | jq .
  else
    local pr_id pr_url
    pr_id="$(echo "$result" | jq -r '.id')"
    pr_url="$(echo "$result" | jq -r '.links.html.href')"
    if [[ "$draft" -eq 1 ]]; then
      echo "Created draft PR #${pr_id}: ${pr_url}"
    else
      echo "Created PR #${pr_id}: ${pr_url}"
    fi
  fi
}

cmd_pr_edit() {
  local pr_id="" title="" body="" base="" draft_flag="" add_reviewers=() remove_reviewers=()
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --help|-h)
        cat <<'HELP'
Edit a pull request. Update title, description, target branch, draft status, or reviewers.

USAGE
  bb pr edit <id> [--title "..."] [--body "..."] [--base <branch>]
             [--ready] [--draft] [--add-reviewer <user>] [--remove-reviewer <user>] [--json]

FLAGS
  --title <text>            New PR title
  --body <text>             New PR description (CommonMark markdown — no GFM extensions)
  --base <branch>           Change target/destination branch
  --ready                   Mark draft PR as ready for review
  --draft                   Convert PR back to draft
  --add-reviewer <user>     Add reviewer (repeatable; see REVIEWER RESOLUTION below)
  --remove-reviewer <user>  Remove reviewer (repeatable)
  --json                    Output raw JSON

REVIEWER RESOLUTION
  Accepts display name, nickname, UUID ({...}), or account_id (24-char hex).
  Display names are resolved from existing PR participants in the repo.
  For users not on any PR yet, use account_id or UUID directly.

EXAMPLES
  bb pr edit 42 --title "New title"
  bb pr edit 42 --base develop
  bb pr edit 42 --ready
  bb pr edit 42 --draft
  bb pr edit 42 --add-reviewer "Alice Smith"
  bb pr edit 42 --remove-reviewer alice --add-reviewer bob
HELP
        exit 0
        ;;
      --title)           title="$2"; shift 2 ;;
      --body)            body="$2"; shift 2 ;;
      --base)            base="$2"; shift 2 ;;
      --ready)           draft_flag="false"; shift ;;
      --draft)           draft_flag="true"; shift ;;
      --add-reviewer)    add_reviewers+=("$2"); shift 2 ;;
      --remove-reviewer) remove_reviewers+=("$2"); shift 2 ;;
      --json)            JSON_OUTPUT=1; shift ;;
      -*)                echo >&2 "unknown flag: $1"; exit 1 ;;
      *)                 pr_id="$1"; shift ;;
    esac
  done

  if [[ -z "$pr_id" ]]; then
    echo >&2 "usage: bb pr edit <id> [--title \"...\"] [--body \"...\"] [--base branch] [--ready] [--draft] [--add-reviewer user] [--remove-reviewer user]"
    exit 1
  fi

  local ws repo
  ws="$(bb_workspace)"
  repo="$(bb_repo)"

  # Fetch current PR state
  local current
  current="$(bb_api_call GET "/repositories/${ws}/${repo}/pullrequests/${pr_id}")"

  # Build update payload starting from current values
  local payload="{}"

  # Title
  if [[ -n "$title" ]]; then
    payload="$(echo "$payload" | jq --arg t "$title" '. + {title: $t}')"
  fi

  # Body/description
  if [[ -n "$body" ]]; then
    payload="$(echo "$payload" | jq --arg b "$body" '. + {description: $b}')"
  fi

  # Destination/base branch
  if [[ -n "$base" ]]; then
    payload="$(echo "$payload" | jq --arg b "$base" '. + {destination: {branch: {name: $b}}}')"
  fi

  # Draft status
  if [[ -n "$draft_flag" ]]; then
    payload="$(echo "$payload" | jq --argjson d "$draft_flag" '. + {draft: $d}')"
  fi

  # Reviewer changes
  if [[ ${#add_reviewers[@]} -gt 0 || ${#remove_reviewers[@]} -gt 0 ]]; then
    # Get current reviewer account_ids
    local current_reviewers
    current_reviewers="$(echo "$current" | jq '[.reviewers[]? | {account_id}]')"

    # Resolve and add new reviewers
    for r in "${add_reviewers[@]}"; do
      local obj
      obj="$(bb_resolve_user "$r")" || exit 1
      local aid
      aid="$(echo "$obj" | jq -r '.account_id // empty')"
      if [[ -n "$aid" ]]; then
        current_reviewers="$(echo "$current_reviewers" | jq --arg id "$aid" '. + [{"account_id": $id}] | unique_by(.account_id)')"
      else
        # UUID-based — convert to that format
        current_reviewers="$(echo "$current_reviewers" | jq --argjson obj "$obj" '. + [$obj]')"
      fi
    done

    # Remove reviewers — match against current PR reviewers by name, UUID, or account_id
    for r in "${remove_reviewers[@]}"; do
      r="$(bb_nfc "$r")"
      local before_count after_count
      before_count="$(echo "$current_reviewers" | jq 'length')"
      # Try matching by account_id, UUID, display_name, or nickname from the PR's reviewer data
      current_reviewers="$(echo "$current" | jq --arg r "$r" --argjson cr "$current_reviewers" '
        # Find the account_id to remove by matching against the full reviewer objects
        (.reviewers // []) as $full |
        ($full | map(select(
          .account_id == $r or .uuid == $r or .display_name == $r or .nickname == $r
        )) | map(.account_id)) as $remove_ids |
        $cr | map(select(.account_id as $aid | $remove_ids | index($aid) | not))')"
      after_count="$(echo "$current_reviewers" | jq 'length')"
      if [[ "$before_count" -eq "$after_count" ]]; then
        echo >&2 "warning: reviewer '$r' not found on PR #${pr_id}"
      fi
    done

    payload="$(echo "$payload" | jq --argjson r "$current_reviewers" '. + {reviewers: $r}')"
  fi

  if [[ "$payload" == "{}" ]]; then
    echo >&2 "error: nothing to update — specify --title, --body, --base, --ready, --draft, --add-reviewer, or --remove-reviewer"
    exit 1
  fi

  local result
  result="$(bb_api_call PUT "/repositories/${ws}/${repo}/pullrequests/${pr_id}" -d "$payload")"

  if [[ "${JSON_OUTPUT:-}" == "1" ]]; then
    echo "$result" | jq .
  else
    echo "Updated PR #${pr_id}"
    # Show what changed
    [[ -n "$title" ]] && echo "  Title: $(echo "$result" | jq -r '.title')"
    [[ -n "$base" ]] && echo "  Target: $(echo "$result" | jq -r '.destination.branch.name')"
    [[ "$draft_flag" == "false" ]] && echo "  Status: Ready for review"
    [[ "$draft_flag" == "true" ]] && echo "  Status: Draft"
    if [[ ${#add_reviewers[@]} -gt 0 || ${#remove_reviewers[@]} -gt 0 ]]; then
      echo "  Reviewers: $(echo "$result" | jq -r '[.reviewers[].display_name] | join(", ") // "(none)"')"
    fi
  fi
}

cmd_pr_tasks() {
  local pr_id="" resolve_id="" reopen_id=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --help|-h)
        cat <<'HELP'
List, resolve, or reopen tasks on a pull request.

USAGE
  bb pr tasks <id> [--resolve <task_id>] [--reopen <task_id>] [--json]

FLAGS
  --resolve <task_id>   Mark task as resolved
  --reopen <task_id>    Reopen a resolved task
  --json                Output raw JSON

Without flags, lists all tasks. Use --resolve or --reopen to change state.

EXAMPLES
  bb pr tasks 42
  bb pr tasks 42 --resolve 12345
  bb pr tasks 42 --reopen 12345
HELP
        exit 0
        ;;
      --resolve) resolve_id="$2"; shift 2 ;;
      --reopen)  reopen_id="$2"; shift 2 ;;
      --json)    JSON_OUTPUT=1; shift ;;
      -*)        echo >&2 "unknown flag: $1"; exit 1 ;;
      *)         pr_id="$1"; shift ;;
    esac
  done

  if [[ -z "$pr_id" ]]; then
    echo >&2 "usage: bb pr tasks <id> [--resolve <task_id>] [--reopen <task_id>]"
    exit 1
  fi

  local ws repo
  ws="$(bb_workspace)"
  repo="$(bb_repo)"

  # Resolve a task
  if [[ -n "$resolve_id" ]]; then
    local result
    result="$(bb_api_call PUT "/repositories/${ws}/${repo}/pullrequests/${pr_id}/tasks/${resolve_id}" \
      -d '{"state": "RESOLVED"}')"
    if [[ "${JSON_OUTPUT:-}" == "1" ]]; then
      echo "$result" | jq .
    else
      echo "Resolved task #${resolve_id} on PR #${pr_id}"
    fi
    return
  fi

  # Reopen a task
  if [[ -n "$reopen_id" ]]; then
    local result
    result="$(bb_api_call PUT "/repositories/${ws}/${repo}/pullrequests/${pr_id}/tasks/${reopen_id}" \
      -d '{"state": "UNRESOLVED"}')"
    if [[ "${JSON_OUTPUT:-}" == "1" ]]; then
      echo "$result" | jq .
    else
      echo "Reopened task #${reopen_id} on PR #${pr_id}"
    fi
    return
  fi

  # List tasks
  local result
  result="$(bb_api_call GET "/repositories/${ws}/${repo}/pullrequests/${pr_id}/tasks")"

  if [[ "${JSON_OUTPUT:-}" == "1" ]]; then
    echo "$result" | jq '.values'
  else
    local count
    count="$(echo "$result" | jq '.values | length')"
    if [[ "$count" -eq 0 ]]; then
      echo "No tasks on PR #${pr_id}"
    else
      echo "ID   STATE   CREATOR   TEXT"
      echo "$result" | jq -r '.values[] | [
        (.id | tostring),
        .state,
        (.creator.display_name // .creator.nickname // "unknown"),
        (.content.raw // "(empty)" | gsub("\n"; " ") | .[:80])
      ] | @tsv' | column -t -s $'\t'
    fi
  fi
}

cmd_pr_comment() {
  local pr_id="" body="" file="" line="" resolve_id="" unresolve_id=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --help|-h)
        cat <<'HELP'
Add, resolve, or unresolve a comment on a pull request.

USAGE
  bb pr comment <id> --body "..." [--file <path>] [--line <num>]
                [--resolve <id>] [--unresolve <id>] [--json]

FLAGS
  --body <text>             Comment text in CommonMark markdown (required for new comments)
  --file <path>             File path for inline comment
  --line <num>              Line number for inline comment (requires --file)
  --resolve <comment_id>    Resolve a comment thread
  --unresolve <comment_id>  Unresolve a comment thread
  --json                    Output raw JSON

Use --file and --line together for inline code comments.
Use --resolve or --unresolve without --body to change thread state.

EXAMPLES
  bb pr comment 42 --body "Looks good!"
  bb pr comment 42 --body "Needs null check" --file src/auth.ts --line 15
  bb pr comment 42 --resolve 12345
  bb pr comment 42 --unresolve 12345
HELP
        exit 0
        ;;
      --body)      body="$2"; shift 2 ;;
      --file)      file="$2"; shift 2 ;;
      --line)      line="$2"; shift 2 ;;
      --resolve)   resolve_id="$2"; shift 2 ;;
      --unresolve) unresolve_id="$2"; shift 2 ;;
      --json)      JSON_OUTPUT=1; shift ;;
      -*)          echo >&2 "unknown flag: $1"; exit 1 ;;
      *)           pr_id="$1"; shift ;;
    esac
  done

  if [[ -z "$pr_id" ]]; then
    echo >&2 "usage: bb pr comment <id> --body \"...\" [--file path] [--line num] [--resolve <comment_id>] [--unresolve <comment_id>] [--json]"
    exit 1
  fi

  local ws repo
  ws="$(bb_workspace)"
  repo="$(bb_repo)"

  # Resolve a comment
  if [[ -n "$resolve_id" ]]; then
    local result
    result="$(bb_api_call POST "/repositories/${ws}/${repo}/pullrequests/${pr_id}/comments/${resolve_id}/resolve" -d '{}')"
    if [[ "${JSON_OUTPUT:-}" == "1" ]]; then
      echo "$result" | jq .
    else
      echo "Resolved comment #${resolve_id} on PR #${pr_id}"
    fi
    return
  fi

  # Unresolve a comment
  if [[ -n "$unresolve_id" ]]; then
    bb_api_call DELETE "/repositories/${ws}/${repo}/pullrequests/${pr_id}/comments/${unresolve_id}/resolve" > /dev/null
    if [[ "${JSON_OUTPUT:-}" == "1" ]]; then
      echo '{}'
    else
      echo "Unresolved comment #${unresolve_id} on PR #${pr_id}"
    fi
    return
  fi

  # Create a comment
  if [[ -z "$body" ]]; then
    echo >&2 "error: --body is required (or use --resolve / --unresolve)"
    exit 1
  fi

  if [[ -n "$line" && -z "$file" ]]; then
    echo >&2 "error: --line requires --file"
    exit 1
  fi

  if [[ -n "$line" && ! "$line" =~ ^[0-9]+$ ]]; then
    echo >&2 "error: --line must be a number, got '$line'"
    exit 1
  fi

  local payload
  if [[ -n "$file" ]]; then
    payload="$(jq -n \
      --arg body "$body" \
      --arg file "$file" \
      --arg line "${line:-}" \
      '{
        content: { raw: $body },
        inline: ({ path: $file } + (if $line != "" then { to: ($line | tonumber) } else {} end))
      }')"
  else
    payload="$(jq -n --arg body "$body" '{ content: { raw: $body } }')"
  fi

  local result
  result="$(bb_api_call POST "/repositories/${ws}/${repo}/pullrequests/${pr_id}/comments" -d "$payload")"

  if [[ "${JSON_OUTPUT:-}" == "1" ]]; then
    echo "$result" | jq .
  else
    local comment_id
    comment_id="$(echo "$result" | jq -r '.id')"
    echo "Comment #${comment_id} added to PR #${pr_id}"
  fi
}

cmd_pr_review() {
  local pr_id="" approve=0 comment=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --help|-h)
        cat <<'HELP'
Approve a pull request, optionally with a comment.

USAGE
  bb pr review <id> --approve [--comment "..."] [--json]

FLAGS
  --approve          Approve the PR (required)
  --comment <text>   Post a comment alongside the approval
  --json             Output raw JSON

EXAMPLES
  bb pr review 42 --approve
  bb pr review 42 --approve --comment "LGTM"
HELP
        exit 0
        ;;
      --approve) approve=1; shift ;;
      --comment) comment="$2"; shift 2 ;;
      --json)    JSON_OUTPUT=1; shift ;;
      -*)        echo >&2 "unknown flag: $1"; exit 1 ;;
      *)         pr_id="$1"; shift ;;
    esac
  done

  if [[ -z "$pr_id" ]]; then
    echo >&2 "usage: bb pr review <id> --approve [--comment \"...\"]"
    exit 1
  fi

  local ws repo
  ws="$(bb_workspace)"
  repo="$(bb_repo)"

  if [[ "$approve" -eq 1 ]]; then
    local result
    # Send an empty JSON object: bb_api_call always sets Content-Type:
    # application/json, and Bitbucket rejects a POST that advertises a JSON body
    # but sends none with HTTP 400. /approve takes no fields, so {} is correct.
    result="$(bb_api_call POST "/repositories/${ws}/${repo}/pullrequests/${pr_id}/approve" -d '{}')"
    if [[ "${JSON_OUTPUT:-}" != "1" ]]; then
      echo "Approved PR #${pr_id}"
    else
      echo "$result" | jq .
    fi
  fi

  if [[ -n "$comment" ]]; then
    cmd_pr_comment "$pr_id" --body "$comment" || {
      echo >&2 "warning: PR was approved but comment failed to post"
      return 1
    }
  fi

  if [[ "$approve" -eq 0 && -z "$comment" ]]; then
    echo >&2 "error: specify --approve and/or --comment"
    exit 1
  fi
}

cmd_pr_merge() {
  local pr_id="" strategy="merge" delete_branch=0
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --help|-h)
        cat <<'HELP'
Merge a pull request.

USAGE
  bb pr merge <id> [--squash|--merge] [--delete-branch] [--json]

FLAGS
  --squash          Squash and merge
  --merge           Merge commit (default)
  --delete-branch   Delete source branch after merge
  --json            Output raw JSON

EXAMPLES
  bb pr merge 42
  bb pr merge 42 --squash --delete-branch
HELP
        exit 0
        ;;
      --squash)        strategy="squash"; shift ;;
      --merge)         strategy="merge"; shift ;;
      --delete-branch) delete_branch=1; shift ;;
      --json)          JSON_OUTPUT=1; shift ;;
      -*)              echo >&2 "unknown flag: $1"; exit 1 ;;
      *)               pr_id="$1"; shift ;;
    esac
  done

  if [[ -z "$pr_id" ]]; then
    echo >&2 "usage: bb pr merge <id> [--squash|--merge] [--delete-branch]"
    exit 1
  fi

  local ws repo
  ws="$(bb_workspace)"
  repo="$(bb_repo)"

  local merge_strategy
  case "$strategy" in
    squash) merge_strategy="squash" ;;
    *)      merge_strategy="merge_commit" ;;
  esac

  local payload
  payload="$(jq -n \
    --arg strategy "$merge_strategy" \
    --argjson close "$delete_branch" \
    '{ type: "pullrequest", merge_strategy: $strategy, close_source_branch: ($close == 1) }')"

  local result
  result="$(bb_api_call POST "/repositories/${ws}/${repo}/pullrequests/${pr_id}/merge" -d "$payload")"

  if [[ "${JSON_OUTPUT:-}" == "1" ]]; then
    echo "$result" | jq .
  else
    echo "Merged PR #${pr_id} (strategy: ${strategy})"
  fi
}

cmd_pr_close() {
  local pr_id=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --help|-h)
        cat <<'HELP'
Decline and close a pull request.

USAGE
  bb pr close <id> [--json]

FLAGS
  --json   Output raw JSON

EXAMPLES
  bb pr close 42
HELP
        exit 0
        ;;
      --json)    JSON_OUTPUT=1; shift ;;
      -*)        echo >&2 "unknown flag: $1"; exit 1 ;;
      *)         pr_id="$1"; shift ;;
    esac
  done

  if [[ -z "$pr_id" ]]; then
    echo >&2 "usage: bb pr close <id> [--json]"
    exit 1
  fi

  local ws repo
  ws="$(bb_workspace)"
  repo="$(bb_repo)"

  local result
  # Empty body + Content-Type: application/json would 400 (same as /approve);
  # send {} explicitly.
  result="$(bb_api_call POST "/repositories/${ws}/${repo}/pullrequests/${pr_id}/decline" -d '{}')"

  if [[ "${JSON_OUTPUT:-}" == "1" ]]; then
    echo "$result" | jq .
  else
    echo "Closed PR #${pr_id}"
  fi
}

# --- Helpers: URL encoding ---------------------------------------------------

bb_resolve_ref() {
  # Resolve a branch/tag name to a commit hash for use in /src/{hash}/{path}.
  # Bitbucket's /src/ endpoint treats slashes in branch names (e.g. feature/foo)
  # as path separators, so we must resolve to a hash first.
  local ref="$1" ws repo
  ws="$(bb_workspace)"
  repo="$(bb_repo)"

  # If it already looks like a hex hash, use as-is
  if [[ "$ref" =~ ^[0-9a-f]{7,40}$ ]]; then
    echo "$ref"
    return
  fi

  # Try branches first, then tags
  local result hash
  result="$(bb_api_call GET "/repositories/${ws}/${repo}/refs/branches/${ref}" 2>/dev/null)" && {
    hash="$(echo "$result" | jq -r '.target.hash // empty')"
    if [[ -n "$hash" ]]; then echo "$hash"; return; fi
  }
  result="$(bb_api_call GET "/repositories/${ws}/${repo}/refs/tags/${ref}" 2>/dev/null)" && {
    hash="$(echo "$result" | jq -r '.target.hash // empty')"
    if [[ -n "$hash" ]]; then echo "$hash"; return; fi
  }

  # Fallback: use ref as-is (may work for simple names without slashes)
  echo "$ref"
}

cmd_pr_diff() {
  local pr_id="" show_stat=0
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --help|-h)
        cat <<'HELP'
Show the diff for a pull request.

USAGE
  bb pr diff <id> [--stat] [--json]

FLAGS
  --stat   Show diffstat summary instead of full diff
  --json   Output raw JSON (only with --stat)

EXAMPLES
  bb pr diff 42
  bb pr diff 42 | head -50
  bb pr diff 42 --stat
  bb pr diff 42 --stat --json
HELP
        exit 0
        ;;
      --stat) show_stat=1; shift ;;
      --json) JSON_OUTPUT=1; shift ;;
      -*)     echo >&2 "unknown flag: $1"; exit 1 ;;
      *)      pr_id="$1"; shift ;;
    esac
  done

  if [[ -z "$pr_id" ]]; then
    echo >&2 "usage: bb pr diff <id> [--stat] [--json]"
    exit 1
  fi

  local ws repo
  ws="$(bb_workspace)"
  repo="$(bb_repo)"

  if [[ "$show_stat" -eq 1 ]]; then
    local result
    result="$(bb_paginate "/repositories/${ws}/${repo}/pullrequests/${pr_id}/diffstat")"
    if [[ "${JSON_OUTPUT:-}" == "1" ]]; then
      echo "$result" | jq .
    else
      local count
      count="$(echo "$result" | jq 'length')"
      if [[ "$count" -eq 0 ]]; then
        echo "No changes"
      else
        echo "STATUS   ADDED   REMOVED   PATH"
        echo "$result" | bb_format_diffstat
      fi
    fi
  else
    bb_api_raw "/repositories/${ws}/${repo}/pullrequests/${pr_id}/diff"
  fi
}

cmd_pr_status() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --help|-h)
        cat <<'HELP'
Show pull requests relevant to you (authored or reviewing).

USAGE
  bb pr status [--json]

FLAGS
  --json   Output raw JSON {authored, reviewing}

EXAMPLES
  bb pr status
  bb pr status --json | jq '.reviewing[].title'
HELP
        exit 0
        ;;
      --json) JSON_OUTPUT=1; shift ;;
      -*)     echo >&2 "unknown flag: $1"; exit 1 ;;
      *)      echo >&2 "unknown argument: $1"; exit 1 ;;
    esac
  done

  local ws repo
  ws="$(bb_workspace)"
  repo="$(bb_repo)"

  local my_id
  my_id="$(bb_api_call GET /user | jq -r '.account_id')"

  local prs
  prs="$(bb_paginate "/repositories/${ws}/${repo}/pullrequests?state=OPEN")"

  local authored reviewing
  authored="$(echo "$prs" | jq --arg id "$my_id" '[.[] | select(.author.account_id == $id)]')"
  reviewing="$(echo "$prs" | jq --arg id "$my_id" '[.[] | select(.author.account_id != $id and ([.reviewers[]?.account_id] | index($id)))]')"

  if [[ "${JSON_OUTPUT:-}" == "1" ]]; then
    jq -n --argjson a "$authored" --argjson r "$reviewing" '{authored: $a, reviewing: $r}'
  else
    local a_count r_count
    a_count="$(echo "$authored" | jq 'length')"
    r_count="$(echo "$reviewing" | jq 'length')"

    echo "Authored ($a_count):"
    if [[ "$a_count" -eq 0 ]]; then
      echo "  (none)"
    else
      echo "ID   STATE   AUTHOR   BRANCH   TITLE"
      echo "$authored" | bb_format_pr_list
    fi

    echo ""
    echo "Reviewing ($r_count):"
    if [[ "$r_count" -eq 0 ]]; then
      echo "  (none)"
    else
      echo "ID   STATE   AUTHOR   BRANCH   TITLE"
      echo "$reviewing" | bb_format_pr_list
    fi
  fi
}

cmd_pr_activity() {
  local pr_id=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --help|-h)
        cat <<'HELP'
Show the activity timeline for a pull request.

USAGE
  bb pr activity <id> [--json]

FLAGS
  --json   Output raw JSON array

EXAMPLES
  bb pr activity 42
  bb pr activity 42 --json | jq '.[].update.state'
HELP
        exit 0
        ;;
      --json) JSON_OUTPUT=1; shift ;;
      -*)     echo >&2 "unknown flag: $1"; exit 1 ;;
      *)      pr_id="$1"; shift ;;
    esac
  done

  if [[ -z "$pr_id" ]]; then
    echo >&2 "usage: bb pr activity <id> [--json]"
    exit 1
  fi

  local ws repo
  ws="$(bb_workspace)"
  repo="$(bb_repo)"

  local result
  result="$(bb_paginate "/repositories/${ws}/${repo}/pullrequests/${pr_id}/activity")"

  if [[ "${JSON_OUTPUT:-}" == "1" ]]; then
    echo "$result" | jq .
  else
    local count
    count="$(echo "$result" | jq 'length')"
    if [[ "$count" -eq 0 ]]; then
      echo "No activity on PR #${pr_id}"
    else
      echo "DATE   TYPE   AUTHOR   SUMMARY"
      echo "$result" | jq -r '.[] | [
        (if .comment then .comment.created_on elif .approval then .approval.date elif .update then .update.date else "?" end | split("T")[0]),
        (if .comment then "comment" elif .approval then "approval" elif .update then "update" else "?" end),
        (if .comment then (.comment.user.display_name // "?") elif .approval then (.approval.user.display_name // "?") elif .update then (.update.author.display_name // "?") else "?" end),
        (if .comment then (.comment.content.raw // "" | gsub("\n"; " ") | .[:60]) elif .approval then "approved" elif .update then .update.state else "?" end)
      ] | @tsv' | column -t -s $'\t'
    fi
  fi
}

# --- Subcommands: source -----------------------------------------------------

cmd_source_ls() {
  local ref="" path=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --help|-h)
        cat <<'HELP'
List files and directories at a given path.

USAGE
  bb source ls [path] [--ref <ref>] [--json]

FLAGS
  --ref <ref>   Branch, tag, or commit SHA (default: current branch)
  --json        Output raw JSON array of file objects

EXAMPLES
  bb source ls
  bb source ls src/
  bb source ls --ref develop
  bb source ls --ref v1.0.0 --json
HELP
        exit 0
        ;;
      --ref)  ref="$2"; shift 2 ;;
      --json) JSON_OUTPUT=1; shift ;;
      -*)     echo >&2 "unknown flag: $1"; exit 1 ;;
      *)      path="$1"; shift ;;
    esac
  done

  [[ -z "$ref" ]] && ref="$(bb_current_ref)"
  local resolved_ref
  resolved_ref="$(bb_resolve_ref "$ref")"

  local ws repo
  ws="$(bb_workspace)"
  repo="$(bb_repo)"

  local api_path="/repositories/${ws}/${repo}/src/${resolved_ref}/${path}"
  local result
  result="$(bb_paginate "$api_path")"

  if [[ "${JSON_OUTPUT:-}" == "1" ]]; then
    echo "$result" | jq .
  else
    local count
    count="$(echo "$result" | jq 'length')"
    if [[ "$count" -eq 0 ]]; then
      echo "No files found"
    else
      echo "TYPE   SIZE   PATH"
      echo "$result" | jq -r '.[] | [
        (if .type == "commit_directory" then "dir" else "file" end),
        (if .type == "commit_directory" then "-" else (.size | tostring) end),
        .path
      ] | @tsv' | column -t -s $'\t'
    fi
  fi
}

cmd_source_cat() {
  local ref="" path="" raw=0
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --help|-h)
        cat <<'HELP'
Print file contents to stdout.

USAGE
  bb source cat <path> [--ref <ref>] [--raw]

FLAGS
  --ref <ref>   Branch, tag, or commit SHA (default: current branch)
  --raw         Always output raw content (skip JSON check; for piping)

EXAMPLES
  bb source cat README.md
  bb source cat src/main.ts --ref develop
  bb source cat package.json --ref v1.0.0
  bb source cat config.yml | head -20
HELP
        exit 0
        ;;
      --ref)  ref="$2"; shift 2 ;;
      --raw)  raw=1; shift ;;
      --json) JSON_OUTPUT=1; shift ;;
      -*)     echo >&2 "unknown flag: $1"; exit 1 ;;
      *)      path="$1"; shift ;;
    esac
  done

  if [[ -z "$path" ]]; then
    echo >&2 "usage: bb source cat <path> [--ref <ref>] [--raw]"
    exit 1
  fi

  [[ -z "$ref" ]] && ref="$(bb_current_ref)"
  local resolved_ref
  resolved_ref="$(bb_resolve_ref "$ref")"

  local ws repo
  ws="$(bb_workspace)"
  repo="$(bb_repo)"

  # Check if path is a directory by fetching metadata
  local meta
  meta="$(bb_api_call GET "/repositories/${ws}/${repo}/src/${resolved_ref}/${path}?format=meta")" || exit 1
  local file_type
  file_type="$(echo "$meta" | jq -r '.type // empty')"
  if [[ "$file_type" == "commit_directory" ]]; then
    echo >&2 "error: '${path}' is a directory — use 'bb source ls ${path}' instead"
    exit 1
  fi

  local api_path="/repositories/${ws}/${repo}/src/${resolved_ref}/${path}"
  bb_api_raw "$api_path"
  echo  # trailing newline for terminal friendliness
}

cmd_source_branches() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --help|-h)
        cat <<'HELP'
List branches in the repository.

USAGE
  bb source branches [--json]

FLAGS
  --json   Output raw JSON array

EXAMPLES
  bb source branches
  bb source branches --json | jq '.[].name'
HELP
        exit 0
        ;;
      --json) JSON_OUTPUT=1; shift ;;
      -*)     echo >&2 "unknown flag: $1"; exit 1 ;;
      *)      echo >&2 "unknown argument: $1"; exit 1 ;;
    esac
  done

  local ws repo
  ws="$(bb_workspace)"
  repo="$(bb_repo)"

  local result
  result="$(bb_paginate "/repositories/${ws}/${repo}/refs/branches")"

  if [[ "${JSON_OUTPUT:-}" == "1" ]]; then
    echo "$result" | jq .
  else
    local count
    count="$(echo "$result" | jq 'length')"
    if [[ "$count" -eq 0 ]]; then
      echo "No branches found"
    else
      # Detect default branch
      local default_branch
      default_branch="$(bb_api_call GET "/repositories/${ws}/${repo}" | jq -r '.mainbranch.name // empty' 2>/dev/null)" || default_branch=""

      echo "NAME   TARGET   MESSAGE"
      echo "$result" | jq -r --arg def "$default_branch" '.[] | [
        (if .name == $def then "* " + .name else "  " + .name end),
        (.target.hash[:12] // "?"),
        (.target.message // "" | gsub("\n"; " ") | .[:60])
      ] | @tsv' | column -t -s $'\t'
    fi
  fi
}

cmd_source_tags() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --help|-h)
        cat <<'HELP'
List tags in the repository.

USAGE
  bb source tags [--json]

FLAGS
  --json   Output raw JSON array

EXAMPLES
  bb source tags
  bb source tags --json | jq '.[].name'
HELP
        exit 0
        ;;
      --json) JSON_OUTPUT=1; shift ;;
      -*)     echo >&2 "unknown flag: $1"; exit 1 ;;
      *)      echo >&2 "unknown argument: $1"; exit 1 ;;
    esac
  done

  local ws repo
  ws="$(bb_workspace)"
  repo="$(bb_repo)"

  local result
  result="$(bb_paginate "/repositories/${ws}/${repo}/refs/tags")"

  if [[ "${JSON_OUTPUT:-}" == "1" ]]; then
    echo "$result" | jq .
  else
    local count
    count="$(echo "$result" | jq 'length')"
    if [[ "$count" -eq 0 ]]; then
      echo "No tags found"
    else
      echo "NAME   TARGET   DATE   MESSAGE"
      echo "$result" | jq -r '.[] | [
        .name,
        (.target.hash[:12] // "?"),
        (.target.date // "" | split("T")[0] // "?"),
        (.target.message // "" | gsub("\n"; " ") | .[:60])
      ] | @tsv' | column -t -s $'\t'
    fi
  fi
}

cmd_source_search() {
  local query="" search_all=0
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --help|-h)
        cat <<'HELP'
Search code in the repository (or entire workspace).

USAGE
  bb source search <query> [--all] [--json]

FLAGS
  --all    Search entire workspace (default: scoped to current repo)
  --json   Output raw JSON array

Supports Bitbucket search syntax (e.g., "class Foo", "lang:python TODO").

EXAMPLES
  bb source search "TODO"
  bb source search "className" --all
  bb source search "lang:typescript interface" --json
HELP
        exit 0
        ;;
      --all)  search_all=1; shift ;;
      --json) JSON_OUTPUT=1; shift ;;
      -*)     echo >&2 "unknown flag: $1"; exit 1 ;;
      *)      query="$1"; shift ;;
    esac
  done

  if [[ -z "$query" ]]; then
    echo >&2 "usage: bb source search <query> [--all] [--json]"
    exit 1
  fi

  local ws repo
  ws="$(bb_workspace)"
  repo="$(bb_repo)"

  # Scope to current repo by default
  local search_query="$query"
  if [[ "$search_all" -eq 0 ]]; then
    search_query="repo:${repo} ${query}"
  fi

  local encoded_query
  encoded_query="$(printf '%s' "$search_query" | jq -sRr @uri)"

  local result
  result="$(bb_paginate "/workspaces/${ws}/search/code?search_query=${encoded_query}")"

  if [[ "${JSON_OUTPUT:-}" == "1" ]]; then
    echo "$result" | jq .
  else
    local count
    count="$(echo "$result" | jq 'length')"
    if [[ "$count" -eq 0 ]]; then
      echo "No results found"
    else
      echo "REPO   FILE   MATCHES   LINES"
      echo "$result" | jq -r '.[] | [
        (.file.links.self.href | split("/")[6] // "?"),
        .file.path,
        (.content_match_count | tostring),
        ([.content_matches[]?.lines[]?.line] | map(tostring) | join(",") | if . == "" then "-" else . end)
      ] | @tsv' | column -t -s $'\t'
    fi
  fi
}

cmd_source_commits() {
  local ref=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --help|-h)
        cat <<'HELP'
List commits on a branch, or show a single commit by SHA.

USAGE
  bb source commits [branch] [--json]
  bb source commits <sha> [--json]

FLAGS
  --json   Output raw JSON

EXAMPLES
  bb source commits
  bb source commits develop
  bb source commits abc123def4
  bb source commits --json
HELP
        exit 0
        ;;
      --json) JSON_OUTPUT=1; shift ;;
      -*)     echo >&2 "unknown flag: $1"; exit 1 ;;
      *)      ref="$1"; shift ;;
    esac
  done

  [[ -z "$ref" ]] && ref="$(bb_current_ref)"

  local ws repo
  ws="$(bb_workspace)"
  repo="$(bb_repo)"

  # If arg looks like a hex SHA, show single commit detail
  if [[ "$ref" =~ ^[0-9a-f]+$ ]]; then
    local result
    result="$(bb_api_call GET "/repositories/${ws}/${repo}/commit/${ref}")"
    if [[ "${JSON_OUTPUT:-}" == "1" ]]; then
      echo "$result" | jq .
    else
      echo "$result" | jq -r '"Commit:   " + .hash[:12],
        "Author:   " + (.author.raw // "?"),
        "Date:     " + (.date // "?"),
        "Parents:  " + ([.parents[].hash[:12]] | join(", ")),
        "",
        (.message // "(no message)")'
    fi
    return
  fi

  # Otherwise list recent commits on the branch (single page, no full pagination)
  local result
  result="$(bb_api_call GET "/repositories/${ws}/${repo}/commits/${ref}?pagelen=30")"

  if [[ "${JSON_OUTPUT:-}" == "1" ]]; then
    echo "$result" | jq .
  else
    local count
    count="$(echo "$result" | jq '.values | length')"
    if [[ "$count" -eq 0 ]]; then
      echo "No commits found"
    else
      echo "HASH   DATE   AUTHOR   MESSAGE"
      echo "$result" | jq -r '.values[] | [
        .hash[:12],
        (.date | split("T")[0]),
        (.author.user.display_name // .author.raw // "?"),
        (.message // "" | split("\n")[0] | .[:60])
      ] | @tsv' | column -t -s $'\t'
    fi
  fi
}

cmd_source_diff() {
  local spec="" show_stat=0
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --help|-h)
        cat <<'HELP'
Show diff between two refs.

USAGE
  bb source diff <base>..<head> [--stat] [--json]

FLAGS
  --stat   Show diffstat summary instead of full diff
  --json   Output raw JSON (only with --stat)

Uses git-style spec: base..head (e.g., main..feature/x).

EXAMPLES
  bb source diff main..feature/x
  bb source diff main..develop --stat
  bb source diff abc123..def456
HELP
        exit 0
        ;;
      --stat) show_stat=1; shift ;;
      --json) JSON_OUTPUT=1; shift ;;
      -*)     echo >&2 "unknown flag: $1"; exit 1 ;;
      *)      spec="$1"; shift ;;
    esac
  done

  if [[ -z "$spec" || "$spec" != *..* ]]; then
    echo >&2 "usage: bb source diff <base>..<head> [--stat] [--json]"
    echo >&2 "  Example: bb source diff main..feature/x"
    exit 1
  fi

  local ws repo
  ws="$(bb_workspace)"
  repo="$(bb_repo)"

  # Bitbucket uses {new}..{old} (opposite of git's {old}..{new})
  local left="${spec%..*}"
  local right="${spec##*..}"
  local api_spec="${right}..${left}"

  if [[ "$show_stat" -eq 1 ]]; then
    local result
    result="$(bb_paginate "/repositories/${ws}/${repo}/diffstat/${api_spec}")"
    if [[ "${JSON_OUTPUT:-}" == "1" ]]; then
      echo "$result" | jq .
    else
      local count
      count="$(echo "$result" | jq 'length')"
      if [[ "$count" -eq 0 ]]; then
        echo "No changes"
      else
        echo "STATUS   ADDED   REMOVED   PATH"
        echo "$result" | bb_format_diffstat
      fi
    fi
  else
    bb_api_raw "/repositories/${ws}/${repo}/diff/${api_spec}"
  fi
}

# --- Raw API access ----------------------------------------------------------

cmd_api() {
  local method="GET" path="" data=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --help|-h)
        cat <<'HELP'
Make a raw Bitbucket API call with correct authentication.

Escape hatch for API endpoints not yet wrapped by bb commands.
Paths are relative to https://api.bitbucket.org/2.0.

USAGE
  bb api <path>
  bb api <path> --method <METHOD> [--data <json>]

FLAGS
  --method <METHOD>   HTTP method: GET, POST, PUT, DELETE (default: GET)
  --data <json>       Request body (JSON string)

PATH SHORTCUTS
  {ws}                Replaced with auto-detected workspace
  {repo}              Replaced with auto-detected repo slug
  {ws}/{repo}         Both replaced

EXAMPLES
  bb api /user
  bb api /repositories/{ws}/{repo}
  bb api /repositories/{ws}/{repo}/pullrequests/42
  bb api /repositories/{ws}/{repo}/pullrequests/42/decline --method POST
  bb api /repositories/{ws}/{repo}/pullrequests --method POST --data '{"title":"test","source":{"branch":{"name":"my-branch"}}}'
HELP
        exit 0
        ;;
      --method) method="${2^^}"; shift 2 ;;
      --data)   data="$2"; shift 2 ;;
      -*)       echo >&2 "unknown flag: $1"; exit 1 ;;
      *)        path="$1"; shift ;;
    esac
  done

  if [[ -z "$path" ]]; then
    echo >&2 "usage: bb api <path> [--method METHOD] [--data json]"
    exit 1
  fi

  # Replace {ws} and {repo} shortcuts
  if [[ "$path" == *"{ws}"* || "$path" == *"{repo}"* ]]; then
    local ws repo
    ws="$(bb_workspace)"
    repo="$(bb_repo)"
    path="${path//\{ws\}/$ws}"
    path="${path//\{repo\}/$repo}"
  fi

  local result
  if [[ -n "$data" ]]; then
    result="$(bb_api_call "$method" "$path" -d "$data")"
  else
    result="$(bb_api_call "$method" "$path")"
  fi

  echo "$result" | jq .
}

# --- Main dispatch -----------------------------------------------------------

usage() {
  cat <<'EOF'
bb — Bitbucket Cloud CLI

Usage: bb <command> [flags]

Setup:
  bb auth login

Auth:
  auth login          Log in with an Atlassian API token
  auth status         Show authenticated user

Pull Requests:
  pr list             List pull requests
  pr view <id>        View a pull request
  pr create           Create a pull request
  pr edit <id>        Edit a PR (title, body, base, reviewers, --ready/--draft)
  pr comment <id>     Comment on a pull request (create, resolve, unresolve)
  pr review <id>      Approve a pull request
  pr merge <id>       Merge a pull request
  pr close <id>       Decline a pull request
  pr tasks <id>       List, resolve, or reopen tasks
  pr diff <id>        Show PR diff (or --stat for summary)
  pr status           Show PRs you authored or are reviewing
  pr activity <id>    Show PR activity timeline

Raw API:
  api <path>          Make a raw API call with correct auth (escape hatch)

Source:
  source ls [path]    List files and directories
  source cat <path>   Print file contents
  source branches     List branches
  source tags         List tags
  source search <q>   Search code in the repository
  source commits [ref] List commits (or show one by SHA)
  source diff <spec>  Compare two refs (or --stat for summary)

Global flags:
  -R workspace/repo   Specify repository (default: auto-detect from git remote)
  --json              Output raw JSON

Environment:
  BB_TOKEN            API token (overrides keychain)
  BB_EMAIL            Account email (overrides keychain)

Examples:
  bb pr list
  bb pr list --state merged --json
  bb pr view 42 --comments
  bb pr create --title "Add feature" --body "Details..." --reviewer alice
  bb pr create --title "WIP" --draft
  bb pr edit 42 --add-reviewer bob --remove-reviewer alice
  bb pr edit 42 --ready
  bb pr edit 42 --base develop
  bb pr comment 42 --body "Looks good!"
  bb pr comment 42 --resolve 12345
  bb pr tasks 42
  bb pr tasks 42 --resolve 12345
  bb pr merge 42 --squash --delete-branch
  bb source ls
  bb source ls src/ --ref develop
  bb source cat README.md
  bb source cat package.json --ref v1.0.0
  bb source branches
  bb source tags --json
  bb pr diff 42
  bb pr diff 42 --stat
  bb pr status
  bb pr activity 42
  bb source search "TODO"
  bb source search "className" --all
  bb source commits
  bb source commits develop
  bb source commits abc123
  bb source diff main..feature/x
  bb source diff main..feature/x --stat
  bb api /repositories/{ws}/{repo}
  bb api /repositories/{ws}/{repo}/pullrequests/42/decline --method POST
EOF
}

# Parse global flags
while [[ $# -gt 0 ]]; do
  case "$1" in
    -R)
      if [[ "$2" != */* ]]; then
        echo >&2 "error: -R requires workspace/repo format (e.g., -R quatico/my-repo)"
        exit 1
      fi
      _BB_WORKSPACE="${2%%/*}"
      _BB_REPO="${2##*/}"
      shift 2
      ;;
    --version|-v)
      echo "bb ${BB_VERSION}"
      exit 0
      ;;
    --json)
      JSON_OUTPUT=1
      shift
      ;;
    *)
      break
      ;;
  esac
done

case "${1:-help}" in
  auth)
    case "${2:-status}" in
      status)    shift 2; cmd_auth_status "$@" ;;
      login)     shift 2; cmd_auth_login "$@" ;;
      --help|-h) usage; exit 0 ;;
      *)         echo >&2 "unknown auth command: $2"; exit 1 ;;
    esac
    ;;
  pr)
    case "${2:-list}" in
      list)    shift 2; cmd_pr_list "$@" ;;
      view)    shift 2; cmd_pr_view "$@" ;;
      create)  shift 2; cmd_pr_create "$@" ;;
      edit)    shift 2; cmd_pr_edit "$@" ;;
      tasks)   shift 2; cmd_pr_tasks "$@" ;;
      comment) shift 2; cmd_pr_comment "$@" ;;
      review)  shift 2; cmd_pr_review "$@" ;;
      merge)   shift 2; cmd_pr_merge "$@" ;;
      close)    shift 2; cmd_pr_close "$@" ;;
      diff)     shift 2; cmd_pr_diff "$@" ;;
      status)   shift 2; cmd_pr_status "$@" ;;
      activity) shift 2; cmd_pr_activity "$@" ;;
      --help|-h) usage; exit 0 ;;
      *)       echo >&2 "unknown pr command: $2"; exit 1 ;;
    esac
    ;;
  source)
    case "${2:-ls}" in
      ls)      shift 2; cmd_source_ls "$@" ;;
      cat)     shift 2; cmd_source_cat "$@" ;;
      branches) shift 2; cmd_source_branches "$@" ;;
      tags)     shift 2; cmd_source_tags "$@" ;;
      search)   shift 2; cmd_source_search "$@" ;;
      commits)  shift 2; cmd_source_commits "$@" ;;
      diff)     shift 2; cmd_source_diff "$@" ;;
      --help|-h) usage; exit 0 ;;
      *)       echo >&2 "unknown source command: $2"; exit 1 ;;
    esac
    ;;
  api)
    shift; cmd_api "$@"
    ;;
  help|--help|-h)
    usage
    ;;
  *)
    echo >&2 "unknown command: $1"
    usage >&2
    exit 1
    ;;
esac
